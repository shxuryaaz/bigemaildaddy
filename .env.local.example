# Neon: use the *pooler* host for DATABASE_URL and the *direct* host for DIRECT_URL (Prisma migrations).
# If you see "Can't reach database", wake the project in the Neon dashboard and add a longer connect timeout, e.g.:
# ...?sslmode=require&connect_timeout=15
DATABASE_URL=
DIRECT_URL=
AUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Enable Gmail API on the same GCP project; sign-in uses gmail.send scope (see auth.config.ts).
OPENAI_API_KEY=
GITHUB_TOKEN=
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=
# Hunter.io email finder (optional — 25 free searches/month at hunter.io)
HUNTER_API_KEY=
